rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: readable by anyone authenticated, writable only by the owning document
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Accounts: open access (private app, couple only)
    match /accounts/{accountId} {
      allow read, write: if true;
    }

    // Expenses: open access (private app, couple only)
    match /expenses/{expenseId} {
      allow read, write: if true;
    }

  }
}
